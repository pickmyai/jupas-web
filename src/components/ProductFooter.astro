---
import productsData from "@shared-config/products.json";

interface Props {
  currentProductId?: string;
  lang?: string;
}

const { currentProductId, lang = 'zh-HK' } = Astro.props;
const meta = productsData.meta;
const isChinese = lang.startsWith('zh');

const labels = {
    sectionTitle: isChinese ? '還需要其他學習工具？誠意推薦使用：' : 'Need other learning tools? We recommend:',
    government:   isChinese ? '公務員考試' : 'Government Exams',
    insurance:    isChinese ? '專業考試'   : 'Professional Exams',
    driving:      isChinese ? '駕駛考試'   : 'Driving & Licensing',
    dse:          isChinese ? 'DSE 系列'   : 'DSE Series',
    aiTools:      isChinese ? 'AI 學習工具系列' : 'AI Learning Tools',
    features:     isChinese ? '功能'       : 'Features',
    faq:          isChinese ? '常見問題'   : 'FAQ',
    reviews:      isChinese ? '用家心聲'   : 'Reviews',
    blog:         isChinese ? '學習攻略'   : 'Blog',
    privacy:      isChinese ? '私隱政策'   : 'Privacy Policy',
    terms:        isChinese ? '使用條款'   : 'Terms of Use',
    tagline:      isChinese ? 'JUPAS 計分・入學機會分析・大學面試模擬' : 'JUPAS Score Calculator · Admission Analysis · Interview Prep',
};

const categorizedProducts = [
    {
        title: labels.government,
        items: [
            { id: 'blnst',      name: '基本法及國安法APP',  slogan: '極致精選 BLNST 題庫 ・ 每題附詳細原文解釋',           logo: '/shared-logos/blnst_logo.png',   url: 'https://www.10minquiz.com/zh-hant/blnst-past-paper-question-app' },
            { id: 'cre-chi',    name: 'CRE 中文運用 APP',    slogan: '嚴選 CRE 中文模擬題 ・ 極速掌握中文運用卷',           logo: '/shared-logos/crechi_logo.png',  url: 'https://www.10minquiz.com/zh-hant/cre-chinese-past-paper-question-app' },
            { id: 'cre-eng',    name: 'CRE 英文運用 APP',    slogan: '精選 CRE 英文模擬題 ・ 助你高效備考',                 logo: '/shared-logos/10minquiz.png',    url: 'https://www.10minquiz.com/zh-hant/cre-english-past-paper-question-app' },
            { id: 'cre-apt',    name: 'CRE能力傾向測試 APP', slogan: '能力傾向 Aptitude Test 一站式題庫全面覆蓋', logo: '/shared-logos/creapt_logo.png',  url: 'https://www.10minquiz.com/zh-hant/cre-aptitude-test-question-app' },
            { id: 'jre',        name: '聯合招聘考試 JRE APP', slogan: '最新時事議題 ・ 論點例子示例 ・ 香港公務員JRE備考',   logo: '/shared-logos/jre_logo.png',     url: 'https://www.10minquiz.com/zh-hant/jre-civil-service-exam-app' },
        ],
    },
    {
        title: labels.insurance,
        items: [
            { id: 'iiqe',   name: '保險中介人 IIQE APP',   slogan: 'IIQE 精選模擬題 ・ 全面備考保險考試', logo: '/shared-logos/iiqe1_logo.png', url: 'https://www.10minquiz.com/zh-hant/iiqe-mpfe-insurance-exam-app' },
            { id: 'mpfe',   name: 'MPFE 強積金考試 APP',   slogan: '精選 MPFE 模擬題 ・ 強積金中介人考試',     logo: '/shared-logos/mpfe_logo.png',  url: 'https://www.10minquiz.com/zh-hant/iiqe-mpfe-insurance-exam-app' },
            { id: 'hksi',   name: '證券期貨 HKSI LE APP', slogan: 'HKSI LE 精選模擬題 ・ 證券期貨從業員考試', logo: '/shared-logos/hksi1_logo.png', url: 'https://www.10minquiz.com/zh-hant/hksi-le-securities-futures-exam-app' },
            { id: 'eaqe',   name: '地產代理 EAQE/SQE APP', slogan: '精選 EAQE & SQE 模擬題 ・ 地產代理資格考試', logo: '/shared-logos/eaqe_logo.png',  url: 'https://www.10minquiz.com/zh-hant/eaqe-sqe-estate-agent-exam-app' },
        ],
    },
    {
        title: labels.driving,
        items: [
            { id: 'pvo', name: 'PVO 遊樂船牌 APP', slogan: '精選遊樂船牌模擬題 ・ 二級遊樂船操作人考試', logo: '/shared-logos/pvo_logo.png', url: 'https://www.10minquiz.com/zh-hant/pvo-pleasure-vessel-operator-exam-app' },
            { id: 'taxi', name: '的士筆試 APP', slogan: '精選的士筆試模擬題 ・ 地方試題 / 路線 / 則例全覆蓋', logo: '/shared-logos/taxi_logo.png', url: 'https://www.10minquiz.com/zh-hant/taxi-exam-question-app' },
        ],
    },
    {
        title: labels.dse,
        items: [
            { id: 'jupas',      name: 'DSE Jupas 神器 APP',   slogan: 'JUPAS 計分器 ・ AI 入學機會分析 ・ 大學面試模擬',         logo: '/logo1024.png',                      url: 'https://jupascalculator.app' },
            { id: 'vocabshiba', name: '單詞狗 VocabShiba APP', slogan: '只背CE/AL/DSE必考單詞 ・ 特調統計所有公開試考過的單詞', logo: '/shared-logos/vocabshiba_logo.png', url: 'https://vocabshiba.com' },
            { id: 'dsechi',     name: 'DSE文言文APP',           slogan: 'DSE 文言文必考範文 ・ 收錄 3000+ 精選題庫',            logo: '/shared-logos/dsechi_logo.png',      url: 'https://dseapp.com/dse-chi/' },
            { id: 'dseecon',    name: 'DSE 經濟科APP',          slogan: 'DSE 經濟科精選題庫 ・ 微觀宏觀全覆蓋',                  logo: '/shared-logos/dseecon_logo.png',     url: 'https://dseapp.com/dse-econ/' },
            { id: 'dsebio',     name: 'DSE 生物科APP',          slogan: 'DSE 生物科精選題庫 ・ 細胞遺傳生態全覆蓋',              logo: '/shared-logos/dsebio_logo.png',      url: 'https://dseapp.com/dse-bio/' },
            { id: 'dsechem',    name: 'DSE 化學科APP',          slogan: 'DSE 化學科精選題庫 ・ 有機化學電化學全覆蓋',            logo: '/shared-logos/dsechem_logo.png',     url: 'https://dseapp.com/dse-chem/' },
            { id: 'dsegeog',    name: 'DSE 地理科APP',          slogan: 'DSE 地理科精選題庫 ・ 7 必修 + 4 選修議題全覆蓋',        logo: '/shared-logos/dsegeog_logo.png',     url: 'https://dseapp.com/dse-geog/' },
            { id: 'dsebafs', name: 'DSE BAFS APP', slogan: 'DSE BAFS 企會財精選題庫 ・ 必修 + 會計選修全覆蓋', logo: '/shared-logos/dsebafs_logo.png', url: 'https://www.dseapp.com/dse-bafs' },
            { id: 'dseict', name: 'DSE ICT APP', slogan: 'DSE 資訊及通訊科技精選題庫 ・ 電腦概念程式應用全覆蓋', logo: '/shared-logos/dseict_logo.png', url: 'https://www.dseapp.com/dse-ict' },
            { id: 'dsebafs',   name: 'DSE BAFS APP',          slogan: 'DSE BAFS 企會財精選題庫 ・ 必修 + 會計選修全覆蓋',        logo: '/shared-logos/dsebafs_logo.png',     url: 'https://dseapp.com/dse-bafs/' },
            { id: 'dseict',    name: 'DSE ICT APP',           slogan: 'DSE 資訊及通訊科技精選題庫 ・ 電腦概念程式應用全覆蓋',    logo: '/shared-logos/dseict_logo.png',      url: 'https://dseapp.com/dse-ict/' },
        ],
    },
    {
        title: labels.aiTools,
        items: [
            { id: 'offergod',     name: 'OfferGod 面試神器',    slogan: 'AI 語音模擬面試 ・ 公務員教育醫管局面試實戰練習', logo: '/shared-logos/offergod_logo.png', url: 'https://offergod.app' },
            { id: 'picmyquiz',    name: 'PickMyQuiz',         slogan: 'AI 挖空 ・ AI 題庫 ・ 極速背誦溫習',             logo: '/shared-logos/picmyquiz.png',           url: 'https://picmyquiz.com' },
            { id: 'bookdaddy',    name: 'bookdaddy 二手物品配對', slogan: '二手書交收新體驗 ・ 服務 AI 秒速配對買賣',      logo: '/shared-logos/bookdaddy.png',           url: 'https://www.bookdaddyhk.com' },
            { id: 'sparkmyclass', name: 'SparkMyClass',             slogan: '遊戲化課堂管理平台 ・ 以互動遊戲提升學生參與度', logo: '/shared-logos/sparkmyclass_logo.png',   url: 'https://www.sparkmyclass.com' },
            { id: 'ai-dictation', name: 'AI默書王 智能默書APP', slogan: '24 小時 AI 默書導師 ・ 隨時隨地智能聽寫默寫', logo: '/shared-logos/ai-dictation.png', url: 'https://www.dictateboss.com' },
        ],
    },
].filter(cat => cat.items.some(p => p.id !== currentProductId));
---

<!-- Product Showcase Section -->
<div class="bg-gray-800 px-4 sm:px-6 lg:px-8 py-10">
    <div class="max-w-7xl mx-auto">
        <h3 class="text-gray-300 text-xl font-bold mb-8 text-center tracking-wide">
            {labels.sectionTitle}
        </h3>

        <div class="space-y-8">
            {categorizedProducts.map(category => (
                <div class="space-y-4">
                    <div class="flex items-center gap-2">
                        <div class="h-4 w-1 bg-white/40 rounded-full" />
                        <h4 class="text-white/90 text-sm font-bold uppercase tracking-widest px-1">
                            {category.title}
                        </h4>
                    </div>
                    <div class="grid grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-2 md:gap-3">
                        {category.items.filter(p => p.id !== currentProductId).map(product => (
                            <a
                                href={product.url}
                                target="_blank"
                                rel="nofollow noopener noreferrer"
                                class="group bg-white/10 rounded-xl p-2 md:p-2.5 hover:bg-white/15 transition-all duration-300 hover:-translate-y-0.5 border border-white/10"
                            >
                                <div class="flex items-center gap-2 md:gap-3">
                                    <div class="w-8 h-8 md:w-10 md:h-10 flex items-center justify-center flex-shrink-0 bg-white rounded-lg p-0.5 md:p-1">
                                        <img
                                            src={product.logo}
                                            alt={product.name}
                                            class="w-full h-full object-contain"
                                            width="40"
                                            height="40"
                                            loading="lazy"
                                            decoding="async"
                                        />
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <h5 class="font-medium text-white text-[11px] md:text-xs mb-0.5 leading-tight line-clamp-1 group-hover:text-amber-300 transition-colors">
                                            {product.name}
                                        </h5>
                                        <p class="text-[10px] md:text-xs text-gray-400 leading-snug line-clamp-1 md:line-clamp-2">
                                            {product.slogan}
                                        </p>
                                    </div>
                                </div>
                            </a>
                        ))}
                    </div>
                </div>
            ))}
        </div>
    </div>
</div>

<!-- Footer -->
<footer class="bg-gray-800 text-white py-10">
    <div class="container mx-auto px-6">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="flex items-center gap-3 bg-white rounded-2xl px-4 py-3 shadow-sm">
                <img src="/logo1024.png" alt="DSE Jupas 神器" class="w-9 h-9 object-contain" />
                <div>
                    <div class="font-bold text-gray-900 text-sm">DSE Jupas 神器</div>
                    <div class="text-gray-500 text-xs">{labels.tagline}</div>
                </div>
            </div>
            <div class="flex gap-6 text-gray-400 text-sm">
                <a href="#features" class="hover:text-white transition-colors">{labels.features}</a>
                <a href="#faq" class="hover:text-white transition-colors">{labels.faq}</a>
                <a href="#reviews" class="hover:text-white transition-colors">{labels.reviews}</a>
                <a href="/blog/" class="hover:text-white transition-colors">{labels.blog}</a>
            </div>
            <div class="flex gap-4 text-gray-500 text-xs">
                <a href="/privacy" class="hover:text-gray-300">{labels.privacy}</a>
                <a href="/terms" class="hover:text-gray-300">{labels.terms}</a>
            </div>
        </div>
        <div class="text-center text-gray-600 text-xs mt-8 pt-6 border-t border-gray-700">
            {meta.copyright}
        </div>
    </div>
</footer>
