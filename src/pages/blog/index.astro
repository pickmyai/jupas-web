---
import Layout from '../../layouts/Layout.astro';

const posts = [
    {
        url: '/blog/dse-results-day-2026-guide/',
        image: '/blog-covers/dse-results-day-2026-guide.webp',
        category: '放榜攻略',
        title: 'DSE 放榜 2026 攻略｜7 月 15 日放榜日時間表、JUPAS 改選 48 小時、派位全流程',
        desc: '由放榜前準備、放榜日行動清單，到 48 小時改選同 8 月派位補選，拆清 2026 放榜季每個關鍵日期。',
        readTime: '11 分鐘',
        color: 'text-amber-500 bg-amber-50',
    },
    {
        url: '/blog/jupas-scoring-methods-explained/',
        image: '/blog-covers/jupas-scoring-methods-explained.webp',
        category: '計分攻略',
        title: '同一張 DSE 成績單點解間間大學計分唔同？JUPAS Best 5、4C+2X 全拆解',
        desc: '八大院校點計分可以差幾遠？Best 5、4C+2X、科目加權、加分制一次過拆清。',
        readTime: '12 分鐘',
        color: 'text-amber-500 bg-amber-50',
    },
    {
        url: '/blog/jupas-band-a-strategy/',
        image: '/blog-covers/jupas-band-a-strategy.webp',
        category: '選科策略',
        title: '20 個 JUPAS 志願點排先唔會放榜得個吉？Band A 排位策略全拆解',
        desc: 'Band A 放夢想定保險？用收生 median／LQ 數據，由進取到保底排好 20 個志願。',
        readTime: '11 分鐘',
        color: 'text-sky-600 bg-sky-50',
    },
    {
        url: '/blog/jupas-admission-scores-2026/',
        image: '/blog-covers/jupas-admission-scores-2026.webp',
        category: '收生數據',
        title: '你嘅 DSE 分數夠唔夠入八大熱門科？2026 JUPAS 收生 median、LQ 參考一覽',
        desc: '距離熱門科 median 仲差幾多？醫科、法律、環球商業、計算機等收生分數懶人包。',
        readTime: '13 分鐘',
        color: 'text-amber-500 bg-amber-50',
    },
    {
        url: '/blog/university-interview-preparation/',
        image: '/blog-covers/university-interview-preparation.webp',
        category: '面試攻略',
        title: '大學面試一開口就扣分？醫科、法律、商科常見題 + STAR 答題框架',
        desc: '面試一緊張就口窒窒？拆解神科最常考題型，附 STAR 答題框架同 mock interview 方法。',
        readTime: '12 分鐘',
        color: 'text-sky-600 bg-sky-50',
    },
    {
        url: '/blog/jupas-change-of-choices-guide/',
        image: '/blog-covers/jupas-change-of-choices-guide.webp',
        category: 'JUPAS 流程',
        title: 'DSE 分數比預期差怕入唔到 U？JUPAS 改選時間線同放榜前後逆襲策略',
        desc: '分數失手仲有冇得救？由 12 月到放榜，拆清每個 JUPAS 改選窗口同補位策略。',
        readTime: '10 分鐘',
        color: 'text-amber-500 bg-amber-50',
    },
];
---

<Layout title="JUPAS 升學攻略 | DSE Jupas 神器">
    <!-- Navbar (same as homepage) -->
    <nav class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
        <div class="container mx-auto px-6 h-16 flex items-center justify-between max-w-6xl">
            <a href="/" class="flex items-center gap-2.5">
                <img src="/logo-transparent.png" alt="DSE Jupas 神器" class="w-10 h-10 object-contain" />
                <div class="leading-tight">
                    <span class="font-bold text-gray-900 text-sm block">DSE Jupas 神器</span>
                    <span class="text-[10px] text-gray-400 block">JUPAS 計分 ・ 入學分析 ・ 面試模擬</span>
                </div>
            </a>
            <div class="hidden md:flex items-center gap-8">
                <div class="flex gap-7 text-sm text-gray-500">
                    <a href="/#features" class="hover:text-amber-500 transition-colors font-medium">功能</a>
                    <a href="/#faq" class="hover:text-amber-500 transition-colors font-medium">常見問題</a>
                    <a href="/#reviews" class="hover:text-amber-500 transition-colors font-medium">評價</a>
                    <a href="/blog/" class="text-amber-500 font-semibold">升學攻略</a>
                    <a href="/#scores" class="hover:text-amber-500 transition-colors font-medium">收生分數</a>
                </div>
                <a href="https://apps.apple.com/app/id6780134101"
                    class="bg-amber-500 hover:bg-amber-600 text-white text-sm font-semibold px-5 py-2 rounded-full transition-colors shadow-lg shadow-amber-200">
                    下載 App
                </a>
            </div>
        </div>
    </nav>

    <div class="min-h-screen bg-slate-50 pt-24 pb-20">
        <div class="container mx-auto px-6 max-w-6xl">
            <!-- Header -->
            <div class="text-center mb-14">
                <div class="inline-block text-xs font-bold px-3 py-1 rounded-full mb-4 bg-amber-100 text-amber-600 uppercase tracking-wide">升學資源</div>
                <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-4">JUPAS 升學攻略</h1>
                <p class="text-xl text-slate-500 max-w-2xl mx-auto">由計分、選科到面試準備，幫你系統化升上大學</p>
            </div>

            <!-- Blog Grid -->
            <div class="grid md:grid-cols-3 gap-6">
                {posts.map((post) => (
                    <a href={post.url}
                        class="group bg-white rounded-3xl border border-slate-100 hover:border-amber-200 hover:shadow-xl transition-all duration-300 overflow-hidden flex flex-col">
                        {post.image && (
                            <div class="aspect-[16/9] overflow-hidden bg-amber-50">
                                <img
                                    src={post.image}
                                    alt={post.title}
                                    loading="lazy"
                                    class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500"
                                />
                            </div>
                        )}
                        <div class="p-8 flex flex-col flex-grow">
                            <div class="flex items-center justify-between mb-4">
                                <span class={`text-xs font-bold px-3 py-1 rounded-full ${post.color}`}>{post.category}</span>
                                <span class="text-xs text-slate-400">{post.readTime}閱讀</span>
                            </div>
                            <h2 class="text-xl font-bold text-slate-900 leading-snug group-hover:text-amber-500 transition-colors mb-3">{post.title}</h2>
                            <p class="text-slate-500 leading-relaxed flex-grow">{post.desc}</p>
                            <div class="flex items-center gap-1.5 mt-6 text-amber-500 font-semibold text-sm">
                                閱讀全文
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
                                    <path d="m9 18 6-6-6-6"/>
                                </svg>
                            </div>
                        </div>
                    </a>
                ))}
            </div>

            <!-- CTA -->
            <div class="mt-16 bg-gradient-to-br from-amber-500 to-amber-600 rounded-3xl p-10 text-white text-center">
                <h3 class="text-2xl font-bold mb-3">用 DSE Jupas 神器計分、分析入學機會、操練面試</h3>
                <p class="text-amber-50 mb-6">約 440 個 JUPAS 課程資料 + 八大計分公式 + AI 入學分析，一個 App 搞掂升大學</p>
                <a href="https://apps.apple.com/app/id6780134101"
                    class="inline-block bg-white text-amber-600 font-bold px-8 py-3 rounded-full hover:bg-amber-50 transition-colors shadow-lg">
                    免費下載 DSE Jupas 神器
                </a>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-100 py-10">
        <div class="container mx-auto px-6 text-center text-slate-400 text-sm">
            <a href="/" class="hover:text-amber-500 transition-colors">← 返回首頁</a>
            <span class="mx-3">·</span>
            <span>© 2026 DSE Jupas 神器</span>
        </div>
    </footer>
</Layout>
