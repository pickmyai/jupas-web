---
import Layout from "../../layouts/Layout.astro";
import LandingPage, {
    LANGUAGES,
    translations,
} from "../../components/LandingPage";

export function getStaticPaths() {
    return LANGUAGES.filter((l) => l.code !== "zh-HK").map((l) => ({
        params: { lang: l.code.toLowerCase() },
        props: { code: l.code },
    }));
}

const { lang } = Astro.params;
const { code } = Astro.props;
const t = translations[code] || translations["en"];

// SEO Metadata logic
const isChinese = code.startsWith("zh");
const appName = isChinese ? "DSE Jupas 神器" : "DSE Jupas";
const title = isChinese
    ? `JUPAS 计分器｜${appName} · 免费计分、收生位置、面试练习`
    : "JUPAS Calculator | DSE Jupas · Score, Admission Positions & Interview Practice";
const seoDescription = isChinese
    ? "免费 JUPAS 计分器：输入 DSE 成绩即时计分，涵盖 413 个课程计分及出路评级、历年 median／LQ 参考、Band 排位分析，以及 14 类共 1,232 条大学面试练习题。非官方升学参考工具。"
    : "Free JUPAS calculator: score your DSE results instantly across 413 programme profiles, with historical admission-score positions and 1,232 bilingual interview prompts. Independent reference only; no admission guarantee.";
const description = seoDescription;
---

<Layout title={title} description={description} lang={code}>
    <main>
        <LandingPage client:load initialLang={code} />
    </main>
</Layout>
