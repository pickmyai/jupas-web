---
import Layout from "../../layouts/Layout.astro";
import LandingPage, {
    LANGUAGES,
    translations,
} from "../../components/LandingPage";

export function getStaticPaths() {
    return LANGUAGES.map((l) => ({
        params: { lang: l.code.toLowerCase() },
        props: { code: l.code },
    }));
}

const { lang } = Astro.params;
const { code } = Astro.props;
const t = translations[code] || translations["en"];

// SEO Metadata logic
const isChinese = code.startsWith("zh");
const appName = isChinese ? "DSE Jupas 神器" : "DSE Jupas";
const tagline = isChinese
    ? "JUPAS 計分器｜出路評級・AI 入學機會分析・大學面試模擬・免費下載"
    : "JUPAS Score Calculator・Outcome Rating・AI Admission Analysis・University Interview Sim";
const title = `${appName} - ${tagline}`;
const seoDescription = isChinese
    ? "DSE Jupas 神器一個 App 搞掂升大學：輸入 DSE 成績即時套用八大及自資院校收生計分公式（Best 5、4C+2X、科目加權、加分制），涵蓋約 440 個 JUPAS 課程資料；AI 對比歷年收生 median／LQ 參考值分析入學機會，配合 413 個課程出路評級比較就業、薪酬、抗 AI、升學及技能複利，並提供約 1500 條大學面試練習題模擬操練。非官方升學參考工具，免費下載。"
    : t.hero.subtitle;
const description = seoDescription;
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <LandingPage client:load initialLang={code} />
    </main>
</Layout>
