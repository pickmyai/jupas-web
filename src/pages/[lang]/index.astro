---
import Layout from "../../layouts/Layout.astro";
import LandingPage, {
    LANGUAGES,
    translations,
} from "../../components/LandingPage";

export function getStaticPaths() {
    return LANGUAGES.filter((l) => l.code !== "zh-HK").map((l) => ({
        params: { lang: l.code.toLowerCase() },
        props: { code: l.code },
    }));
}

const { lang } = Astro.params;
const { code } = Astro.props;
const t = translations[code] || translations["en"];

// SEO Metadata logic
const isChinese = code.startsWith("zh");
const appName = isChinese ? "DSE Jupas 神器" : "DSE Jupas";
const tagline = isChinese
    ? "JUPAS 計分、課程比較與面試練習"
    : "JUPAS Calculator, Programme Comparison and Interview Practice";
const title = isChinese ? `${appName} - ${tagline}` : "DSE Jupas | JUPAS Calculator & Interview Practice";
const seoDescription = isChinese
    ? "DSE Jupas 神器提供 413 個 JUPAS 課程計分及出路評級、歷年 median／LQ 參考、Band 排位分析，以及 14 類共 1,232 條大學面試練習題。非官方升學參考工具。"
    : "Explore 413 JUPAS programme profiles, historical admission-score positions and 1,232 bilingual interview prompts. Independent reference only; no admission guarantee.";
const description = seoDescription;
---

<Layout title={title} description={description} lang={code}>
    <main>
        <LandingPage client:load initialLang={code} />
    </main>
</Layout>
