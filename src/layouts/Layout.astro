---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import StructuredData from '../components/StructuredData.astro';
import ProductFooter from '../components/ProductFooter.astro';
import { LANGUAGES } from '../components/LandingPage';

interface ArticleData {
	title: string;
	description: string;
	url: string;
	image?: string;
	datePublished?: string;
	dateModified?: string;
}

interface Props {
	title: string;
    description?: string;
    lang?: string;
    ogImage?: string;
    keywords?: string;
    noindex?: boolean;
    schemaType?: 'website' | 'mobileApplication' | 'article';
    articleData?: ArticleData;
    breadcrumbItems?: Array<{ name: string; url: string }>;
    alternates?: Array<{ lang: string; url: string }>;
    showProductFooter?: boolean;
}

const {
	title,
	description = "DSE Jupas 神器提供 JUPAS 課程計分、歷年收生資料參考、出路評級、志願排序分析及大學面試練習。非官方升學參考工具。",
	lang = "zh-HK",
	ogImage,
	keywords,
	noindex = false,
	schemaType = 'mobileApplication',
	articleData,
	breadcrumbItems,
	alternates: providedAlternates,
	showProductFooter = true,
} = Astro.props;

const isLocalizedHome = ['/', '/en/', '/zh-cn/'].includes(Astro.url.pathname);
const alternates = providedAlternates ?? (isLocalizedHome
    ? LANGUAGES.map(l => ({
        lang: l.code,
        url: l.code === 'zh-HK' ? '/' : `/${l.code.toLowerCase()}/`,
    }))
    : []);
import Analytics from '@vercel/analytics/astro';
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="google-site-verification" content="vvhtX6UkDycwd5jxCOf5IdoJeHAheh_w-VpFmqIx3BM" />

		<SEO
			title={title}
			description={description}
			lang={lang}
			ogImage={ogImage}
			keywords={keywords}
			noindex={noindex}
			alternates={alternates}
		/>

		<StructuredData type={schemaType} articleData={articleData} breadcrumbItems={breadcrumbItems} />

		<title>{title}</title>
	</head>
	<body class="bg-background text-foreground antialiased font-sans">
		<slot />
		{showProductFooter && <ProductFooter currentProductId="jupas" lang={lang} />}
		<script is:inline>
		document.addEventListener('click', function (e) {
		  var a = e.target && e.target.closest && e.target.closest('a[href*="apps.apple.com"], a[href*="play.google.com"]');
		  if (!a) return;
		  var href = a.href || '';
		  var platform = href.indexOf('apps.apple.com') !== -1 ? 'ios' : 'android';
		  var m = platform === 'ios' ? href.match(/id(\d{8,})/) : href.match(/[?&]id=([\w.]+)/);
		  try {
		    var p = new URLSearchParams({ site: 'jupas', app: (m && m[1]) || '', platform: platform, page: location.pathname });
		    if (!(navigator.sendBeacon && navigator.sendBeacon('https://www.pickmyquiz.com/api/track/app-click', p))) {
		      fetch('https://www.pickmyquiz.com/api/track/app-click', { method: 'POST', body: p, keepalive: true });
		    }
		  } catch (err) {}
		}, true);
		</script>
		<Analytics />
	</body>
</html>
<style is:global>
	* { box-sizing: border-box; }
	.font-sans { font-family: -apple-system, BlinkMacSystemFont, 'PingFang TC', 'Microsoft JhengHei', 'Segoe UI', sans-serif; }
	.gradient-text { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
	.hero-gradient { background: linear-gradient(135deg, #fffbeb 0%, #fff 50%, #f0f9ff 100%); }
	.cta-gradient { background: linear-gradient(135deg, #f59e0b 0%, #d97706 60%, #b45309 100%); }
	.card-hover { transition: transform 0.25s ease, box-shadow 0.25s ease; }
	.card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(245,158,11,0.12); }
	:root {
		--background: 0 0% 100%;
		--foreground: 222.2 84% 4.9%;

		--card: 0 0% 100%;
		--card-foreground: 222.2 84% 4.9%;
 
		--popover: 0 0% 100%;
		--popover-foreground: 222.2 84% 4.9%;
 
		--primary: 38 92% 50%; /* #f59e0b Amber (star brand) */
		--primary-foreground: 210 40% 98%;
 
		--secondary: 210 40% 96.1%;
		--secondary-foreground: 222.2 47.4% 11.2%;
 
		--muted: 210 40% 96.1%;
		--muted-foreground: 215.4 16.3% 46.9%;
 
		--accent: 210 40% 96.1%;
		--accent-foreground: 222.2 47.4% 11.2%;
 
		--destructive: 0 84.2% 60.2%;
		--destructive-foreground: 210 40% 98%;

		--border: 214.3 31.8% 91.4%;
		--input: 214.3 31.8% 91.4%;
		--ring: 38 92% 50%;
 
		--radius: 0.75rem;
	}
 
	.dark {
		--background: 222.2 84% 4.9%;
		--foreground: 210 40% 98%;
 
		--card: 222.2 84% 4.9%;
		--card-foreground: 210 40% 98%;
 
		--popover: 222.2 84% 4.9%;
		--popover-foreground: 210 40% 98%;
 
		--primary: 38 92% 50%;
		--primary-foreground: 0 0% 100%;
 
		--secondary: 217.2 32.6% 17.5%;
		--secondary-foreground: 210 40% 98%;
 
		--muted: 217.2 32.6% 17.5%;
		--muted-foreground: 215 20.2% 65.1%;
 
		--accent: 217.2 32.6% 17.5%;
		--accent-foreground: 210 40% 98%;
 
		--destructive: 0 62.8% 30.6%;
		--destructive-foreground: 210 40% 98%;
 
		--border: 217.2 32.6% 17.5%;
		--input: 217.2 32.6% 17.5%;
		--ring: 38 92% 50%;
	}

    html {
        scroll-behavior: smooth;
    }
</style>
